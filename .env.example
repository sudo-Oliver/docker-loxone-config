# Copy to .env and adjust, or run ./setup.sh to auto-configure

# ── Platform (set by setup.sh or manually) ────────────────────────────────────
# Apple Silicon + Rosetta 2 / Intel amd64: linux/amd64  ← fastest on Apple Silicon
# Apple Silicon no Rosetta / Linux ARM64:  linux/arm64  ← QEMU-user fallback
# Legacy 32-bit x86:                       linux/386
PLATFORM=linux/amd64

# Matching Dockerfile for the chosen platform:
# linux/amd64  → Dockerfile.amd64       (Debian, wine32 via i386 multiarch, Rosetta on Apple Silicon)
# linux/arm64  → Dockerfile.arm64-qemu  (ARM64 native + qemu-i386-static, Rosetta-independent)
# linux/386    → Dockerfile             (Alpine, native wine32, legacy x86 only)
DOCKERFILE=Dockerfile.amd64

# ── ARM64 QEMU note ───────────────────────────────────────────────────────────
# If PLATFORM=linux/arm64 + DOCKERFILE=Dockerfile.arm64-qemu, run once before build:
#   docker run --rm --privileged multiarch/qemu-user-static --reset -p yes

# ── Security ──────────────────────────────────────────────────────────────────
# Max 8 characters (RFC 6143 limit). Strongly recommended.
VNC_PASSWORD=changeme

# Set to 1 to enable HTTPS + SSL-VNC (uses certs from /config/certs/)
# Self-signed cert is generated automatically when no cert files are present
SECURE_CONNECTION=0

# ── Data Paths ────────────────────────────────────────────────────────────────
CONFIG_PATH=./config
LOXONE_PATH=./config/Loxone

# ── Display ───────────────────────────────────────────────────────────────────
DISPLAY_WIDTH=1920
DISPLAY_HEIGHT=1080

# Keyboard layout: de at ch us en fr
XLANG=de

# ── Ports ─────────────────────────────────────────────────────────────────────
# Bind to 127.0.0.1 for localhost-only access (use SSH tunnel for remote)
HTTP_PORT=5800
VNC_PORT=5900

# ── User ─────────────────────────────────────────────────────────────────────
# Match your host user to avoid permission issues on the config volume
# Run: id    → use the uid/gid shown
USER_ID=1000
GROUP_ID=1000

# ── Behaviour ─────────────────────────────────────────────────────────────────
# Auto-restart Loxone Config if it crashes
KEEP_APP_RUNNING=1
