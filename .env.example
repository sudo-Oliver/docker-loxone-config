# Copy to .env and adjust, or run ./setup.sh to auto-configure

# ── Compose file selection ─────────────────────────────────────────────────────
# KasmVNC (recommended):  docker-compose.yml:docker-compose.kasmvnc.yml
# Classic noVNC (legacy): docker-compose.yml
COMPOSE_FILE=docker-compose.yml:docker-compose.kasmvnc.yml

# ── Display backend ────────────────────────────────────────────────────────────
BACKEND=kasmvnc

# ── Platform (set by setup.sh or manually) ────────────────────────────────────
# Apple Silicon + Rosetta 2 / Intel amd64: linux/amd64
# Apple Silicon no Rosetta / Linux ARM64:  linux/arm64
# Legacy 32-bit x86:                       linux/386
PLATFORM=linux/amd64

# Dockerfile selection (backend × platform):
# KasmVNC  + amd64 → Dockerfile.kasmvnc        (KasmVNC web UI on port 6901)
# KasmVNC  + arm64 → Dockerfile.arm64-kasmvnc  (KasmVNC native ARM64 + QEMU wine)
# Classic  + amd64 → Dockerfile.amd64          (jlesage noVNC, port 5800)
# Classic  + arm64 → Dockerfile.arm64-qemu     (jlesage noVNC + QEMU wine)
# Classic  + 386   → Dockerfile                (jlesage Alpine 32-bit)
DOCKERFILE=Dockerfile.kasmvnc

# ── ARM64 QEMU note ───────────────────────────────────────────────────────────
# If PLATFORM=linux/arm64, run once before build:
#   docker run --rm --privileged multiarch/qemu-user-static --reset -p yes

# ── Security ──────────────────────────────────────────────────────────────────
# KasmVNC: any length. Classic noVNC: max 8 chars (RFC 6143 limit).
VNC_PASSWORD=changeme

# Set to 1 to enable HTTPS + SSL-VNC (uses certs from /config/certs/)
# Self-signed cert is generated automatically when no cert files are present
SECURE_CONNECTION=0

# ── Data Paths ────────────────────────────────────────────────────────────────
CONFIG_PATH=./config
LOXONE_PATH=./config/Loxone

# ── Display ───────────────────────────────────────────────────────────────────
DISPLAY_WIDTH=1920
DISPLAY_HEIGHT=1080

# Keyboard layout: de at ch us en fr
XLANG=de

# ── Display ───────────────────────────────────────────────────────────────────
# KasmVNC: starting resolution only — dynamically resizes to browser window
# Classic: fixed resolution
VNC_RESOLUTION=1920x1080

# ── Ports ─────────────────────────────────────────────────────────────────────
# Bind to 127.0.0.1 for localhost-only access (use SSH tunnel for remote)
# KasmVNC: HTTP_PORT=6901, VNC_PORT=5901
# Classic: HTTP_PORT=5800, VNC_PORT=5900
HTTP_PORT=6901
VNC_PORT=5901

# ── User ─────────────────────────────────────────────────────────────────────
# Match your host user to avoid permission issues on the config volume
# Run: id    → use the uid/gid shown
USER_ID=1000
GROUP_ID=1000

# ── Behaviour ─────────────────────────────────────────────────────────────────
# Auto-restart Loxone Config if it crashes
KEEP_APP_RUNNING=1
